# Kakao Local API
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# Naver Search API
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# Instagram scraping (mandatory cloud path to avoid crawl bans)
APIFY_TOKEN=your_apify_api_token_here
# Optional fallback (if you intentionally run non-Apify mode)
INSTAGRAM_SESSION_ID=
INSTAGRAM_CSRFTOKEN=

# Crawler DB
DATABASE_URL=postgresql://yogacrawl:yogacrawl@172.31.46.249:5432/yogacrawl
CRAWL_DB_URL=postgresql://yogacrawl:yogacrawl@172.31.46.249:5432/yogacrawl

# AWS
AWS_S3_BUCKET=yogaq-crawl-raw-ap2
AWS_DEFAULT_REGION=ap-northeast-2

# Optional: load into /etc/environment on EC2 for cron access
# sudo -E sh -c 'cat .env.example >> /etc/environment'
